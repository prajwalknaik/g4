pipeline{
agent any
tools{
maven 'maven'
}
stages{
    stage('checkout'){
      steps{
          git branch:'master',url:'https://github.com/prajwalknaik/g4.git'
      }
}
stage('compile'){
    steps{
        sh 'mvn compile'
    }
}
stage('test'){
    steps{
        sh 'mvn test'
    }
}
stage('package'){
    steps{
        sh 'mvn package'
    }
}
stage('run application'){
    steps{
        sh 'mvn exec:java -Dexec-mainClass="com.example.App"'
    }
}
}
post{
    success{
        echo 'build and deployment successfull'
}
    failure{
        echo 'build failed'
    }
}
}



